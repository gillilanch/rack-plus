DATABASE_URL="postgresql://seher.allahbachayo@localhost:5432/rackapp"
PORT=4000
CATALOG_WEBHOOK_SECRET="foxnewsla"

# Equipment catalog from Google Sheet (no Google Cloud): share link is rewritten to CSV export on the server.
# In Sheets: Share → General access → Anyone with the link → Viewer (so backend fetch works).
FOX_CATALOG_CSV_URL=https://docs.google.com/spreadsheets/d/13aci_txPa9jII7c7MccJdVHicMuQZQECIsBW6Ewof2c/edit?usp=sharing
# Every 30s (min allowed by server is 15s — lower may hit Google rate limits on CSV export).
FOX_CATALOG_SYNC_INTERVAL_MS=30000
FOX_CATALOG_SYNC_ON_STARTUP=1
# When 1, each scheduled/startup sync also deletes DB catalog rows not present in the current sheet (sheet = source of truth).
FOX_CATALOG_PRUNE_ON_SYNC=1
