# Local laptop — copy to backend/.env when using npm run dev (Terminal).
# Match VITE_DEV_API_PORT in frontend/.env.development to the same PORT.

PORT=4000

DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/rackapp"

# Optional:
# ADMIN_TOKEN=

# --- Equipment catalog: shared Google Sheet → Postgres (recommended; no Apps Script) ---
# Paste the browser sheet link; server rewrites it to Google CSV export.
# Share → Anyone with the link → Viewer (unless you set fetch auth below).
# Do NOT set GOOGLE_SHEETS_SPREADSHEET_ID if you want CSV-URL polling (Sheet API path wins if set).
# FOX_CATALOG_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing
# Poll interval (ms). Minimum: 15000 (15s). Omit or 0 = no scheduled sync.
# FOX_CATALOG_SYNC_INTERVAL_MS=15000
# FOX_CATALOG_SYNC_ON_STARTUP=1
# Optional: rows removed from sheet also removed from DB (full mirror).
# FOX_CATALOG_PRUNE_ON_SYNC=1
# Optional authenticated CSV:
# FOX_CATALOG_CSV_FETCH_AUTHORIZATION=Bearer YOUR_TOKEN
# FOX_CATALOG_CSV_FETCH_HEADERS_JSON={"X-Api-Key":"YOUR_KEY"}
#
# Optional webhooks: POST /api/catalog/sync-webhook (CSV body) or /api/catalog/webhook (JSON) — manual/automation only.
CATALOG_WEBHOOK_SECRET="foxnewsla"
#
# Quick checks:
#   curl -s http://127.0.0.1:4000/api/catalog/status
#   curl -s http://127.0.0.1:4000/api/catalog/devices | head -c 200
