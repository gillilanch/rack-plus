# Local laptop — copy to backend/.env when using npm run dev (Terminal).
# Match VITE_DEV_API_PORT in frontend/.env.development to the same PORT.

PORT=4000

DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/rackapp"

# Optional:
# ADMIN_TOKEN=

# --- Equipment catalog (no Google Cloud) ---
# Paste your normal Google Sheet link (…/d/<id>/edit?…) or any HTTPS URL that returns CSV.
# Without the fetch headers below, a Google Sheet must be “Anyone with the link” → Viewer.
# FOX_CATALOG_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing
# Optional: authenticated CSV pull (private URL / API key). Authorization overrides the same key in JSON if both set.
# FOX_CATALOG_CSV_FETCH_AUTHORIZATION=Bearer YOUR_TOKEN
# FOX_CATALOG_CSV_FETCH_HEADERS_JSON={"X-Api-Key":"YOUR_KEY"}
# FOX_CATALOG_SYNC_INTERVAL_MS=30000
# FOX_CATALOG_SYNC_ON_STARTUP=1
# FOX_CATALOG_PRUNE_ON_SYNC=1
#
# Private sheet push (no public link): POST /api/catalog/sync-webhook with CSV body; header x-catalog-webhook-secret
# must match this value (use a long random string). For JSON push (Apps Script array or { rows: [...] }), use
# POST /api/catalog/sync-structured-webhook or POST /api/catalog/webhook with the same secret via
# x-catalog-webhook-secret OR Authorization: Bearer <same secret>.
# CATALOG_WEBHOOK_SECRET=
