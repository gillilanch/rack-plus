# Copy to .env and adjust.
PORT=4000

# --- Database URL (pick one) ---
#
# If you use Docker Compose in the repo root (docker compose up -d):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rackapp"
#
# If Docker is NOT installed, use local Postgres instead, e.g. Homebrew:
#   brew install postgresql@16
#   brew services start postgresql@16
#   createdb rackapp
# Then (replace YOUR_MAC_USERNAME; often no password on localhost):
# DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/rackapp"
#
# Or Postgres.app / Neon / RDS: paste the provider's connection string here.
#
# Then from backend/: npx prisma migrate deploy && npm run dev
