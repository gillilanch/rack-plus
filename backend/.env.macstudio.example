# Fox Mac Studio (production) — copy to backend/.env on that machine ONLY.
# Do not commit backend/.env.

PORT=4000
NODE_ENV=production

# Staff on the office LAN open (same port for UI + API):
#   http://Foxs-Mac-Studio.local:4000
#   http://10.231.208.225:4000
#
# Admin tools (only from the Mac Studio): http://localhost:4000/admin

# Homebrew Postgres on the same Mac (replace YOUR_USERNAME with output of `whoami`):
DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/rackapp"

# Optional hardening for /admin API:
# ADMIN_TOKEN=generate-a-long-random-string

# --- Equipment catalog: shared Google Sheet → Postgres (poll every 15s) ---
# Use the browser sheet link; do not set GOOGLE_SHEETS_SPREADSHEET_ID unless you use the Google Cloud Sheet API path.
# Sheet: Share → Anyone with the link → Viewer.
# FOX_CATALOG_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing
# FOX_CATALOG_SYNC_INTERVAL_MS=5000
# FOX_CATALOG_SYNC_ON_STARTUP=1
# Optional full mirror (removals in sheet delete DB rows): FOX_CATALOG_PRUNE_ON_SYNC=1
# CATALOG_WEBHOOK_SECRET=your-long-secret
