# Fox Mac Studio (production) — copy to backend/.env on that machine ONLY.
# Do not commit backend/.env.

PORT=4000
NODE_ENV=production

# Staff on the office LAN open (same port for UI + API):
#   http://Foxs-Mac-Studio.local:4000
#   http://10.231.208.225:4000
#
# Admin tools (only from the Mac Studio): http://localhost:4000/admin

# Homebrew Postgres on the same Mac (replace YOUR_USERNAME with output of `whoami`):
DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/rackapp"

# Optional hardening for /admin API:
# ADMIN_TOKEN=generate-a-long-random-string
