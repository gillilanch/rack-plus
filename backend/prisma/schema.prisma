generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rack {
  id             String       @id @default(uuid())
  name           String
  totalHeightU   Int          @map("total_height_u")
  /// Inches per 1U (RU), e.g. 1.75 for standard racks.
  inchesPerRU    Float        @default(1.75) @map("inches_per_ru")
  /// Front-panel width (e.g. 19" EIA equipment width).
  rackWidthInches Float       @default(19) @map("rack_width_inches")
  slackAllowance Float        @map("slack_allowance")
  connections    Json         @default("[]")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  devices        RackDevice[]

  @@map("rack")
}

model RackDevice {
  id                   String       @id @default(uuid())
  rackId               String       @map("rack_id")
  rack                 Rack         @relation(fields: [rackId], references: [id], onDelete: Cascade)
  name                 String
  manufacturer         String       @default("")
  deviceModel          String       @default("") @map("device_model")
  category             String
  heightInU            Int          @map("height_in_u")
  rackPosition         Int?         @map("rack_position")
  physicalHeightInches Decimal?     @map("physical_height_inches") @db.Decimal(10, 2)
  catalogDeviceId      String?      @map("catalog_device_id")
  sortOrder            Int          @default(0) @map("sort_order")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  ports                DevicePort[]

  @@index([rackId])
  @@map("rack_device")
}

model DevicePort {
  id              String     @id @default(uuid())
  rackDeviceId    String     @map("rack_device_id")
  rackDevice      RackDevice @relation(fields: [rackDeviceId], references: [id], onDelete: Cascade)
  connectorType   String     @map("connector_type")
  direction       String
  label           String?
  portCount       Int        @default(1) @map("port_count")
  sortOrder       Int        @default(0) @map("sort_order")

  @@index([rackDeviceId])
  @@map("device_port")
}
