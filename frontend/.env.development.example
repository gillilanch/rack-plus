# Local laptop — copy to frontend/.env.development (Vite loads it during npm run dev).
# Must match backend/.env PORT so /api proxy hits your dev server.

VITE_DEV_API_PORT=4000

# Optional: while the app is open, re-fetch /api/catalog/devices every N ms (Google Sheet / CSV sync → Postgres).
# Use 120000 for every 2 minutes. Omit or set below 10000 to disable.
# Re-fetch /api/catalog/devices while the app is open (min 5000 ms). Match backend poll for fresher UI.
# VITE_CATALOG_POLL_MS=5000

# Optional: same value as backend CATALOG_WEBHOOK_SECRET — enables deleting Postgres catalog rows from the device database UI.
# VITE_CATALOG_WEBHOOK_SECRET=

# Optional: only when the UI is NOT using the Vite proxy (e.g. you open dist/ from another
# static server, or tooling that does not forward /api). Point at your backend origin, no trailing slash.
# VITE_API_BASE_URL=http://127.0.0.1:4000
